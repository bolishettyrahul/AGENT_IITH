# Bright Data — Scraping Browser (puppeteer-core fallback)
# Get from: Control Panel → Scraping Browser zone → Connection strings → Puppeteer WSS
BROWSER_WS=wss://brd-customer-CUSTOMER_ID-zone-ZONE_NAME:PASSWORD@brd.superproxy.io:9222

# Groq — LLM inference (free tier, high rate limits, OpenAI-compatible)
# Get key: console.groq.com → API Keys → Create
GROQ_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
