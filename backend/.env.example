# Bright Data — Scraping Browser (puppeteer-core fallback)
# Get from: Control Panel → Scraping Browser zone → Connection strings → Puppeteer WSS
BROWSER_WS=wss://brd-customer-CUSTOMER_ID-zone-ZONE_NAME:PASSWORD@brd.superproxy.io:9222

# Featherless.ai — LLM inference (OpenAI-compatible)
FEATHERLESS_KEY=your_featherless_api_key_here
FEATHERLESS_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Supabase — database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
